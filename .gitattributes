# Normalize line endings for text files
* text=auto

# Explicitly declare binary files to avoid text normalization
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.mp4 binary
*.pdf binary
*.glb binary
*.bin binary
*.ico binary
*.webp binary

# Treat specific file types as text
*.js text
*.jsx text
*.ts text
*.tsx text
*.json text
*.css text
*.scss text
*.html text
*.md text
*.yml text
*.yaml text
*.xml text
*.xhtml text
