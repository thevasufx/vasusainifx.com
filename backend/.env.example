# ====================
# Backend Configuration
# ====================

# Server port (default: 8080)
PORT=8080

# ==========================================
# OPTIONAL: Google Gemini API Configuration
# ==========================================
# The app runs fine WITHOUT this API key.
# Only set this if you want to enable the AI chat feature.
#
# To get a FREE API key:
# 1. Visit https://aistudio.google.com/app/apikey
# 2. Create a new API key
# 3. Copy it below
#
# Leave this blank or commented out to disable the chat feature.
GEMINI_API_KEY=

